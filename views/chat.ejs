<!DOCTYPE html>
<html>

<head>
    <title>Chat</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <div class="container">
        <h1>Chat</h1>

        <a href="/groups">← Back to Groups</a>

        <hr>

        <div>
            <% messages.forEach(msg => { %>

                <!-- MESSAGE BOX -->
                <div class="message">
                    <strong><%= msg.username %></strong>:
                    <%= msg.message_text %><br>
                    <small><%= msg.sent_at %></small>
                </div>

                <!-- SHOW EMOJIS -->
                <div>
                    <% if (msg.reactions && msg.reactions.length > 0) { %>
                        <% msg.reactions.forEach(r => { %>
                            <span><%= r.emoji %></span>
                        <% }) %>
                    <% } %>
                </div>

                <!-- ADD EMOJI -->
                <form method="POST" action="/messages/<%= msg.message_id %>/react">
                    <input type="hidden" name="groupId" value="<%= groupId %>">

                    <button type="submit" name="emoji" value="👍">👍</button>
                    <button type="submit" name="emoji" value="❤️">❤️</button>
                    <button type="submit" name="emoji" value="😂">😂</button>
                </form>

                <hr>

            <% }) %>
        </div>

        <!-- SEND MESSAGE -->
        <form method="POST" action="/groups/<%= groupId %>/message">
            <input type="text" name="message" placeholder="Type a message..." required>
            <button type="submit">Send</button>
        </form>
    </div>
</body>

</html>