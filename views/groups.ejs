<!DOCTYPE html>
<html>
<head>
    <title>Groups</title>
</head>
<body>

<h1>Welcome <%= user.username %></h1>

<form method="POST" action="/logout">
    <button type="submit">Logout</button>
</form>

<h2>Your Groups (<%= total %>)</h2>

<ul>
    <% groups.forEach(group => { %>
        <li>
            <strong><%= group.group_name %></strong><br>

            Last message:
            <%= group.last_message_time ? group.last_message_time : "No messages yet" %><br>

            Unread:
            <%= group.unread_count %><br>

            <a href="/groups/<%= group.group_id %>">Open Chat</a>
        </li>
        <hr>
    <% }) %>
</ul>

<a href="/groups/create">Create New Group</a>

</body>
</html>